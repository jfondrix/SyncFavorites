{
  "manifest_version": 3,
  "name": "SyncFav",
  "version": "1.0.0",
  "description": "Sync bookmarks across Brave, Chrome, and Edge using your own VPS.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
