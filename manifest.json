{
  "manifest_version": 3,
  "name": "SyncFav",
  "version": "1.0.0",
  "description": "Sync bookmarks across Brave, Chrome, and Edge using your own VPS.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
